<script is:inline>
  (function() {
    const params = new URLSearchParams(window.location.search);
    if (!params.has('cms-edit')) return;

    console.log("🚀 Tryb PRO-CMS Aktywny");

    // 1. Obsługa danych GLOBALNYCH (telefon, email itp.)
    const globalElements = document.querySelectorAll('[data-cms-global]');
    globalElements.forEach(el => {
      el.contentEditable = "true";
      el.style.borderBottom = "2px solid #22c55e"; // Zielony dla globalnych
      
      el.addEventListener('input', () => {
        const key = el.getAttribute('data-cms-global');
        const newValue = el.innerText;

        // Synchronizacja wizualna: zmień wszystkie inne pola z tym samym kluczem na stronie
        document.querySelectorAll(`[data-cms-global="${key}"]`).forEach(syncEl => {
          if (syncEl !== el) syncEl.innerText = newValue;
        });
      });

      el.addEventListener('blur', () => sendChange(el, true));
    });

    // 2. Obsługa danych LOKALNYCH (teksty na podstronach)
    const localElements = document.querySelectorAll('[data-cms]');
    localElements.forEach(el => {
      el.contentEditable = "true";
      el.style.borderBottom = "2px solid #f97316"; // Pomarańczowy dla lokalnych
      el.addEventListener('blur', () => sendChange(el, false));
    });

    function sendChange(el, isGlobal) {
      window.parent.postMessage({
        type: 'cms-text-change',
        scope: isGlobal ? 'global' : 'local',
        key: el.getAttribute(isGlobal ? 'data-cms-global' : 'data-cms'),
        value: el.innerText,
        pageId: window.location.pathname
      }, '*');
    }

    window.parent.postMessage({ type: 'cms-ready' }, '*');
  })();
</script>

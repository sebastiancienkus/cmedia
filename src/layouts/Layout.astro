---
// src/layouts/Layout.astro
import '../styles/global.css'; // 👈 Upewnij się, że ta ścieżka jest poprawna!

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-slate-900 text-white antialiased">
		
		<slot />

		<script is:inline>
  (function() {
    const params = new URLSearchParams(window.location.search);
    if (!params.has('cms-edit')) return;

    console.log("⚡ Tryb LIVE-DATA: Synchronizacja z serwerem...");

    // 1. Pobieramy świeży JSON z serwera (omijamy cache przez ?v=)
    fetch('/content.json?v=' + Date.now())
      .then(res => res.json())
      .then(data => {
        console.log("📦 Dane pobrane pomyślnie:", data);

        // 2. Podmieniamy teksty LOKALNE (np. index.heroTitle)
        document.querySelectorAll('[data-cms]').forEach(el => {
          const fullKey = el.getAttribute('data-cms');
          if (fullKey.includes('.')) {
            const [page, key] = fullKey.split('.');
            // Sprawdzamy czy klucz istnieje w JSONIE i podmieniamy
            if (data.pages && data.pages[page] && data.pages[page][key]) {
              el.innerText = data.pages[page][key];
            }
          }
        });

        // 3. Podmieniamy teksty GLOBALNE (np. phone, email)
        document.querySelectorAll('[data-cms-global]').forEach(el => {
          const key = el.getAttribute('data-cms-global');
          if (data.global && data.global[key]) {
            el.innerText = data.global[key];
          }
        });

        // 4. Gdy dane są już "świeże", aktywujemy edycję wizualną
        activateEditable();
      })
      .catch(err => console.error("❌ Błąd synchronizacji danych:", err));

    function activateEditable() {
      const allEditable = document.querySelectorAll('[data-cms], [data-cms-global]');
      
      allEditable.forEach(el => {
        el.contentEditable = "true";
        el.style.outline = "none";
        el.style.cursor = "text";
        el.style.borderBottom = el.hasAttribute('data-cms-global') ? "2px dashed #22c55e" : "2px dashed #f97316";

        el.addEventListener('blur', () => {
          window.parent.postMessage({
            type: 'cms-text-change',
            scope: el.hasAttribute('data-cms-global') ? 'global' : 'local',
            key: el.getAttribute('data-cms-global') || el.getAttribute('data-cms'),
            value: el.innerText
          }, '*');
        });
      });
      
      // Informujemy panel, że jesteśmy gotowi
      window.parent.postMessage({ type: 'cms-ready' }, '*');
    }
  })();
</script>
	</body>
</html>

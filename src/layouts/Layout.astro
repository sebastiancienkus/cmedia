---
// src/layouts/Layout.astro
import '../styles/global.css'; 
const { title } = Astro.props;
---
<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<style is:global>
			/* 🎨 FUNDAMENT STYLE GUIDE */
			:root {
				--color-brand: #f97316;
				--color-link: #3b82f6;
				--color-site-bg: #0f172a;
				--color-content-bg: #1e293b;
				--color-border: #334155;
				--color-heading: #ffffff;
				--color-text: #94a3b8;
			}

			body { background-color: var(--color-site-bg); color: var(--color-text); transition: background 0.3s ease; }
			h1, h2, h3, h4 { color: var(--color-heading); }
			a { color: var(--color-link); }
a:hover { color: var(--color-brand); filter: brightness(1.2); }

			/* 🔧 RAMKI EDYTORA CMS */
			.cms-editing {
				border: 2px dashed var(--color-border) !important;
				padding: 6px !important;
				border-radius: 8px !important;
				outline: none !important;
				transition: all 0.2s ease !important;
				display: inline-block;
				cursor: text !important;
			}
			.cms-editing:hover { background-color: rgba(255, 255, 255, 0.03); }

		</style>
	</head>
	<body>
		<slot />

		<script is:inline>
		(function() {
			const params = new URLSearchParams(window.location.search);
			const isEditMode = params.has('cms-edit');

			function applyTheme(theme) {
				if (!theme || !theme.colors) return;
				const root = document.documentElement;
				const c = theme.colors;
				const map = {
					'brand': c.brand, 'link': c.link, 'site-bg': c.site_bg,
					'content-bg': c.content_bg, 'border': c.border_color,
					'heading': c.heading, 'text': c.text
				};
				for (const [key, val] of Object.entries(map)) {
					if (val) root.style.setProperty(`--color-${key}`, val);
				}
			}

			async function syncContent() {
				try {
					const res = await fetch('/content.json?v=' + Date.now());
					if (!res.ok) return;
					const data = await res.json();
					
					// Aplikuj kolory
					if (data.global?.theme) applyTheme(data.global.theme);

					// Podmień teksty [data-cms]
					document.querySelectorAll('[data-cms]').forEach(el => {
						const [page, key] = el.getAttribute('data-cms').split('.');
						if (data.pages?.[page]?.[key]) el.innerText = data.pages[page][key];
					});
					// Podmień teksty [data-cms-global]
					document.querySelectorAll('[data-cms-global]').forEach(el => {
						const key = el.getAttribute('data-cms-global');
						if (data.global?.[key]) el.innerText = data.global[key];
					});
				} catch (e) { console.log("Static Mode"); }
			}

			function initCMS() {
				document.querySelectorAll('[data-cms], [data-cms-global]').forEach(el => {
					el.contentEditable = "true";
					el.classList.add('cms-editing');
					el.addEventListener('input', () => {
						window.parent.postMessage({
							type: 'cms-text-change',
							scope: el.hasAttribute('data-cms-global') ? 'global' : 'local',
							key: el.getAttribute('data-cms-global') || el.getAttribute('data-cms'),
							value: el.innerText
						}, '*');
					});
				});
				window.parent.postMessage({ type: 'cms-ready' }, '*');
			}

			syncContent().then(() => { if (isEditMode) initCMS(); });
		})();
		</script>
	</body>
</html>

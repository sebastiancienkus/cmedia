---
// src/layouts/Layout.astro
import '../styles/global.css'; // 👈 Upewnij się, że ta ścieżka jest poprawna!

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-slate-900 text-white antialiased">
		
		<slot />

	<script is:inline>
  (function() {
    const params = new URLSearchParams(window.location.search);
    const isEditMode = params.has('cms-edit');

    // ⚡ FUNKCJA SYNCHRONIZACJI (Działa dla wszystkich!)
    async function syncLiveContent() {
      try {
        // Pobieramy świeży plik JSON z serwera Seohost
        const res = await fetch('/content.json?v=' + Date.now());
        if (!res.ok) return; // Jeśli pliku nie ma, zostajemy przy danych z budowania
        const data = await res.json();

        // Podmiana tekstów lokalnych
        document.querySelectorAll('[data-cms]').forEach(el => {
          const fullKey = el.getAttribute('data-cms');
          const [page, key] = fullKey.split('.');
          if (data.pages?.[page]?.[key]) {
            // Podmieniamy tylko jeśli tekst jest inny (żeby nie psuć focusu w edytorze)
            if (el.innerText !== data.pages[page][key]) {
              el.innerText = data.pages[page][key];
            }
          }
        });

        // Podmiana tekstów globalnych
        document.querySelectorAll('[data-cms-global]').forEach(el => {
          const key = el.getAttribute('data-cms-global');
          if (data.global?.[key] && el.innerText !== data.global[key]) {
            el.innerText = data.global[key];
          }
        });
      } catch (e) {
        console.log("Strona używa danych statycznych z buildu.");
      }
    }

    // 1. Zawsze synchronizuj dane po załadowaniu
    syncLiveContent().then(() => {
      // 2. Jeśli jesteśmy w trybie edycji, włącz funkcje CMS
      if (isEditMode) {
        initCMS();
      }
    });

    function initCMS() {
      document.querySelectorAll('[data-cms], [data-cms-global]').forEach(el => {
        el.contentEditable = "true";
        el.style.borderBottom = "2px dashed #f97316";
        el.style.outline = "none";
        el.addEventListener('blur', () => {
          window.parent.postMessage({
            type: 'cms-text-change',
            scope: el.hasAttribute('data-cms-global') ? 'global' : 'local',
            key: el.getAttribute('data-cms-global') || el.getAttribute('data-cms'),
            value: el.innerText
          }, '*');
        });
      });
      window.parent.postMessage({ type: 'cms-ready' }, '*');
    }
  })();
</script>
	</body>
</html>

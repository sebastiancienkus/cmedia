---
// src/layouts/Layout.astro
import '../styles/global.css'; // 👈 Upewnij się, że ta ścieżka jest poprawna!

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-slate-900 text-white antialiased">
		
		<slot />

	<script is:inline>
  (function() {
    const params = new URLSearchParams(window.location.search);
    if (!params.has('cms-edit')) return;

    console.log("⚡ Tryb LIVE-SYNC: Pobieranie najświeższych danych...");

    // 1. Funkcja podmieniająca teksty na stronie
    async function refreshContent() {
      try {
        // Pobieramy content.json bezpośrednio z serwera (omijamy cache)
        const res = await fetch('/content.json?v=' + Date.now());
        if (!res.ok) throw new Error("Brak pliku content.json na serwerze");
        const data = await res.json();

        // Podmiana danych LOKALNYCH (np. index.heroTitle)
        document.querySelectorAll('[data-cms]').forEach(el => {
          const fullKey = el.getAttribute('data-cms');
          const [page, key] = fullKey.split('.');
          if (data.pages?.[page]?.[key]) {
            el.innerText = data.pages[page][key];
          }
        });

        // Podmiana danych GLOBALNYCH
        document.querySelectorAll('[data-cms-global]').forEach(el => {
          const key = el.getAttribute('data-cms-global');
          if (data.global?.[key]) {
            el.innerText = data.global[key];
          }
        });

        console.log("✅ Dane zsynchronizowane.");
      } catch (e) {
        console.warn("ℹ️ System czeka na pierwszy zapis, aby utworzyć plik lokalny.");
      }
    }

    // 2. Aktywacja edytora wizualnego
    function initEditable() {
      document.querySelectorAll('[data-cms], [data-cms-global]').forEach(el => {
        el.contentEditable = "true";
        el.style.borderBottom = "2px dashed #f97316";
        el.style.outline = "none";

        el.addEventListener('blur', () => {
          window.parent.postMessage({
            type: 'cms-text-change',
            scope: el.hasAttribute('data-cms-global') ? 'global' : 'local',
            key: el.getAttribute('data-cms-global') || el.getAttribute('data-cms'),
            value: el.innerText
          }, '*');
        });
      });
      window.parent.postMessage({ type: 'cms-ready' }, '*');
    }

    // Odpalamy: Najpierw synchronizacja danych, potem włączenie edycji
    refreshContent().then(initEditable);
  })();
</script>
	</body>
</html>

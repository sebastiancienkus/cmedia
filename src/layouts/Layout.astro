---
// src/layouts/Layout.astro
import '../styles/global.css'; 

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<style is:global>
			/* Styl dla elementów w trybie edycji */
			.cms-editing {
				border: 2px dashed #f97316 !important;
				padding: 6px !important;
				border-radius: 8px !important;
				outline: none !important;
				transition: all 0.2s ease !important;
				display: inline-block; /* Zapobiega rozjeżdżaniu się ramki */
				cursor: text !important;
			}
			.cms-editing:hover {
				border-color: #fb923c !important;
				background-color: rgba(249, 115, 22, 0.05) !important;
			}
		</style>
	</head>
	<body class="bg-slate-900 text-white antialiased">
		
		<slot />

	<script is:inline>
	(function() {
		const params = new URLSearchParams(window.location.search);
		const isEditMode = params.has('cms-edit');

		// 1. FUNKCJA SYNCHRONIZACJI (Pobiera najświeższe dane z serwera)
		async function syncLiveContent() {
			try {
				const res = await fetch('/content.json?v=' + Date.now());
				if (!res.ok) return; 
				const data = await res.json();

				// Podmiana tekstów lokalnych [data-cms]
				document.querySelectorAll('[data-cms]').forEach(el => {
					const fullKey = el.getAttribute('data-cms');
					const [page, key] = fullKey.split('.');
					if (data.pages?.[page]?.[key]) {
						if (el.innerText !== data.pages[page][key]) {
							el.innerText = data.pages[page][key];
						}
					}
				});

				// Podmiana tekstów globalnych [data-cms-global]
				document.querySelectorAll('[data-cms-global]').forEach(el => {
					const key = el.getAttribute('data-cms-global');
					if (data.global?.[key] && el.innerText !== data.global[key]) {
						el.innerText = data.global[key];
					}
				});
			} catch (e) {
				console.log("Strona używa danych statycznych.");
			}
		}

		// 2. FUNKCJA INICJUJĄCA EDYCJĘ (Włącza ramki i nasłuchiwanie klawiatury)
		function initCMS() {
			const editableElements = document.querySelectorAll('[data-cms], [data-cms-global]');
			
			editableElements.forEach(el => {
				el.contentEditable = "true";
				el.classList.add('cms-editing');

				// ⚡ KLUCZOWA ZMIANA: 'input' zamiast 'blur'
				// Wysyła zmianę do panelu przy każdym naciśnięciu klawisza
				el.addEventListener('input', () => {
					window.parent.postMessage({
						type: 'cms-text-change',
						scope: el.hasAttribute('data-cms-global') ? 'global' : 'local',
						key: el.getAttribute('data-cms-global') || el.getAttribute('data-cms'),
						value: el.innerText
					}, '*');
				});
			});

			// Informujemy panel, że ramka jest gotowa
			window.parent.postMessage({ type: 'cms-ready' }, '*');
		}

		// ODPALANIE PROCESU
		syncLiveContent().then(() => {
			if (isEditMode) {
				initCMS();
			}
		});
	})();
	</script>
	</body>
</html>

---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import siteData from '../../public/content.json';
---

<Layout title="CMedia AI | Strona Główna">
    <div class="min-h-screen flex flex-col items-center justify-center bg-slate-900 text-white p-10 text-center">
        <h1 class="text-5xl font-bold text-orange-500 mb-4">{siteData.heroTitle}</h1>
        <p class="text-xl text-slate-300 mb-8">{siteData.heroSubtitle}</p>
        
        <div class="inline-block px-6 py-3 mt-4 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 rounded-full font-mono text-sm">
            Kontakt: {siteData.contactEmail}
        </div>
    </div>
</Layout>
